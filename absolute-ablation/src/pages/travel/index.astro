---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const posts = await getCollection('travel');
const sortedPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout title="Travel | Sarath Sadasivan" description="Stories from the road. Places visited, things learned, moments captured.">
  <div class="min-h-screen bg-[#fafafa]" style="font-family: 'Inter', sans-serif;">
    <!-- Header -->
    <header class="border-b border-gray-200 bg-white/80 backdrop-blur-sm sticky top-0 z-40">
      <div class="max-w-4xl mx-auto px-6 py-4 flex items-center justify-between">
        <a href="/" class="text-sm text-gray-400 hover:text-gray-600 transition-colors flex items-center gap-2">
          <i class="fas fa-arrow-left text-xs"></i> Home
        </a>
        <h1 class="text-lg font-bold text-gray-900">Travel</h1>
        <div class="w-16"></div>
      </div>
    </header>

    <main class="max-w-4xl mx-auto px-6 py-12 md:py-20">
      <div class="mb-12">
        <h2 class="text-3xl md:text-4xl font-extrabold text-gray-900 mb-4">Travel Log</h2>
        <p class="text-lg text-gray-500 leading-relaxed max-w-2xl">Stories from the road. Places visited, things learned, moments captured.</p>
      </div>

      {sortedPosts.length === 0 ? (
        <p class="text-gray-400 text-center py-20">No travel logs yet. Adventures are being planned.</p>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {sortedPosts.map((post) => (
            <a href={`/travel/${post.id}`} class="block group">
              <article class="border border-gray-200 rounded-xl overflow-hidden bg-white hover:border-emerald-300 hover:shadow-lg transition-all duration-200 group-hover:-translate-y-0.5">
                {post.data.coverImage && (
                  <div class="h-48 bg-gray-100 overflow-hidden">
                    <img src={post.data.coverImage} alt={post.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
                  </div>
                )}
                <div class="p-5">
                  <div class="flex flex-wrap items-center gap-2 mb-2">
                    {post.data.location && (
                      <span class="text-xs text-emerald-600 flex items-center gap-1">
                        <i class="fas fa-map-marker-alt text-[0.6rem]"></i> {post.data.location}
                      </span>
                    )}
                    {post.data.readingTime && (
                      <span class="text-xs text-gray-400 flex items-center gap-1">
                        <i class="far fa-clock text-[0.6rem]"></i> {post.data.readingTime}
                      </span>
                    )}
                  </div>
                  <h3 class="text-lg font-bold text-gray-900 mb-2 group-hover:text-emerald-600 transition-colors">{post.data.title}</h3>
                  <p class="text-gray-500 text-sm leading-relaxed mb-3">{post.data.description}</p>
                  <div class="flex items-center justify-between">
                    <div class="flex flex-wrap gap-1.5">
                      {post.data.tags.slice(0, 3).map((tag: string) => (
                        <span class="inline-block px-2 py-0.5 rounded-full text-[0.6rem] font-semibold uppercase tracking-wide bg-emerald-50 text-emerald-700">{tag}</span>
                      ))}
                    </div>
                    <p class="text-xs text-gray-400">
                      {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short' })}
                    </p>
                  </div>
                </div>
              </article>
            </a>
          ))}
        </div>
      )}
    </main>
  </div>
</Layout>
