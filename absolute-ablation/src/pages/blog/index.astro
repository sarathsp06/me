---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import BlogHeader from '../../components/BlogHeader.svelte';
import BlogPostList from '../../components/BlogPostList.svelte';
import BlogFooter from '../../components/BlogFooter.svelte';

const posts = await getCollection('blog');
const sortedPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Extract all unique tags
const allTags = [...new Set(sortedPosts.flatMap(p => p.data.tags))];

// Format posts for the Svelte component
const formattedPosts = sortedPosts.map(post => ({
  title: post.data.title,
  description: post.data.description,
  tags: post.data.tags,
  readingTime: post.data.readingTime || '',
  pubDate: post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }),
  external: post.data.external || '',
  href: post.data.external || `/blog/${post.id}`,
}));
---

<Layout title="Blog | Sarath Sadasivan" description="Writing about software engineering, product management, and building things.">
  <div class="min-h-screen bg-[#fafafa]" style="font-family: 'Inter', sans-serif;">
    <BlogHeader client:load />

    <main class="max-w-4xl mx-auto px-6 py-12 md:py-20">
      <!-- Hero section -->
      <div class="mb-10">
        <div class="hero-badge">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/>
          </svg>
          Writing
        </div>
        <h2 class="text-3xl md:text-4xl font-extrabold text-gray-900 mb-4 tracking-tight">
          Blog
        </h2>
        <p class="text-lg text-gray-500 leading-relaxed max-w-2xl">
          Thoughts on software engineering, product management, prioritization, and building things that work.
        </p>

        <!-- Stats row -->
        <div class="stats-row">
          <div class="stat">
            <span class="stat-number">{sortedPosts.length}</span>
            <span class="stat-label">Posts</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat">
            <span class="stat-number">{allTags.length}</span>
            <span class="stat-label">Topics</span>
          </div>
        </div>
      </div>

      <!-- Interactive blog post list with filtering -->
      <BlogPostList
        client:load
        tags={allTags}
        posts={formattedPosts}
      />
    </main>

    <BlogFooter client:idle />
  </div>
</Layout>

<style>
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.375rem 0.875rem;
    border-radius: 9999px;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    background: linear-gradient(135deg, #eff6ff, #e0e7ff);
    color: #3b82f6;
    border: 1px solid #bfdbfe;
    margin-bottom: 1rem;
  }
  .stats-row {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-top: 1.5rem;
  }
  .stat {
    display: flex;
    align-items: baseline;
    gap: 0.375rem;
  }
  .stat-number {
    font-size: 1.5rem;
    font-weight: 800;
    color: #111827;
  }
  .stat-label {
    font-size: 0.8rem;
    color: #9ca3af;
    font-weight: 500;
  }
  .stat-divider {
    width: 1px;
    height: 1.5rem;
    background: #e5e7eb;
  }
</style>
